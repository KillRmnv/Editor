# Простой куб для отладки графического редактора
# Создан вручную

# Вершины (Vertexes)
# 8 углов куба
v -1.0 -1.0  1.0
v -1.0  1.0  1.0
v  1.0  1.0  1.0
v  1.0 -1.0  1.0
v -1.0 -1.0 -1.0
v -1.0  1.0 -1.0
v  1.0  1.0 -1.0
v  1.0 -1.0 -1.0

# Нормали (Normals)
# 6 направлений для каждой грани (для корректного освещения)
vn  0.0  0.0  1.0
vn  0.0  0.0 -1.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0

# Грани (Faces)
# Формат: f номер_вершины//номер_нормали
# Передняя грань
f 1//1 2//1 3//1 4//1
# Задняя грань
f 8//2 7//2 6//2 5//2
# Верхняя грань
f 2//3 6//3 7//3 3//3
# Нижняя грань
f 1//4 4//4 8//4 5//4
# Правая грань
f 4//5 3//5 7//5 8//5
# Левая грань
f 5//6 6//6 2//6 1//6
